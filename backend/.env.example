# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string (MongoDB Atlas free tier works fine)
# Get one at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/harosfaid?retryWrites=true&w=majority

# JWT secret - use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Default admin account (created automatically the first time you run `npm run seed`)
ADMIN_EMAIL=harosfaidnigerialimited@gmail.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=ABI Harosfaid Admin

# Email notifications (Gmail example - use a 16-character Gmail "App Password",
# NOT your normal Gmail password: https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=harosfaidnigerialimited@gmail.com
EMAIL_PASS=your_16_char_app_password
NOTIFY_EMAIL=harosfaidnigerialimited@gmail.com

# Frontend URL (used for CORS - set to your deployed frontend URL in production)
CLIENT_URL=http://localhost:5500
